# crisis-proof-summit / THE NEW BUSINESS NORMAL — template
# Copy to .env and fill in. NEVER commit .env.

# Supabase project that holds new_business_normal_* tables
SUPABASE_URL=https://nvhzajpstswkmmfrgtiw.supabase.co
SUPABASE_SERVICE_KEY=

# Bearer token for /api/report endpoints (used by admin.html dashboard)
ADMIN_PASSWORD=

GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Payment sync — LEGACY GHL → Bridge Sheet → Supabase pipeline
# (being retired in favor of native Xendit flow below, but kept running
#  for historical orders until cutover is complete)
GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON=
BRIDGE_SHEET_ID=
BRIDGE_SHEET_TAB=payments

# Xendit direct checkout — native /checkout page + /api/xendit-webhook
# - Secret key: Xendit dashboard → Settings → Developers → API Keys
#   Required permission: Money-in products = Write. Nothing else.
# - Callback token: Xendit dashboard → Settings → Developers → Webhooks
#   Shared verification token sent on every webhook as `x-callback-token`.
XENDIT_SECRET_KEY=
XENDIT_CALLBACK_TOKEN=

# Optional — override the base URL used in Xendit success/failure redirects.
# Defaults to https://www.exponential-university.live. Set this on preview
# deployments so Xendit redirects back to the preview domain, not prod.
PUBLIC_BASE_URL=

# Vercel auto-sets this in production for cron auth. Set locally to test.
CRON_SECRET=

# ---------------------------------------------------------------------------
# Meta Ads uploader (scripts/upload_images.py, create_campaign.py, create_ads.py)
# ---------------------------------------------------------------------------

# App credentials — from developers.facebook.com/apps/<app_id>/settings/basic
META_APP_ID=
META_APP_SECRET=

# Long-lived user or page access token with ads_management + pages_manage_ads
# (use Graph Explorer or the fb-token tool to generate)
META_ACCESS_TOKEN=

# Exponential University ad account (prefix required: act_xxxxxxxxxx)
META_AD_ACCOUNT_ID=act_

# Facebook Page that will own the ads
META_PAGE_ID=

# Meta Pixel used for Purchase event on the checkout page
META_PIXEL_ID=

# Ticket purchase URL (no trailing slash, no existing query params preferred)
EVENT_LANDING_PAGE_URL=https://exponential-university.live/

# Optional: override default Graph API version (v22.0 is current as of 2026-04)
# META_GRAPH_VERSION=v22.0
